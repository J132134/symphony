<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Symphony 메뉴바 상태 UI launchd 에이전트.
  로그인 시 자동 실행되어 데몬 상태를 macOS 메뉴바에 표시한다.

  설치:
    make install             # 바이너리 빌드 및 설치
    make install-launchagents  # plist 설치 + launchctl load

  제거:
    launchctl unload ~/Library/LaunchAgents/com.symphony.menubar.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.symphony.menubar</string>

    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.local/bin/symphony</string>
        <string>menubar</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__HOME__/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>__REPO_DIR__/data/menubar.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__REPO_DIR__/data/menubar.stderr.log</string>
</dict>
</plist>
